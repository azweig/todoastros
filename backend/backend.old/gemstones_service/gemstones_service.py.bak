from flask import Flask, request, jsonify
from flask_cors import CORS
import logging
import requests
import os
import json

# Configuración de logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    handlers=[
        logging.FileHandler("gemstones_service.log"),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger("gemstones_service")

app = Flask(__name__)
CORS(app)

# URLs de los servicios
AUTH_SERVICE_URL = os.environ.get("AUTH_SERVICE_URL", "http://auth_service:5050")
OPENAI_SERVICE_URL = os.environ.get("OPENAI_SERVICE_URL", "http://openai_service:5010")

def verify_api_key(api_key):
    """Verifica la validez de la API key con el servicio de autenticación."""
    try:
        response = requests.post(
            f"{AUTH_SERVICE_URL}/auth/verify",
            json={"api_key": api_key}
        )
        return response.status_code == 200 and response.json().get("valid", False)
    except Exception as e:
        logger.error(f"Error al verificar API key: {str(e)}")
        return False

def generate_gemstones_analysis(data, api_key):
    """Genera un análisis de piedras y cristales compatibles utilizando OpenAI."""
    try:
        sun_sign = data.get('sun_sign', '')
        moon_sign = data.get('moon_sign', '')
        ascendant = data.get('ascendant', '')
        
        prompt = f"""Genera un análisis detallado de las piedras preciosas, semipreciosas y cristales más compatibles y beneficiosos para una persona con Sol en {sun_sign}, Luna en {moon_sign} y Ascendente en {ascendant}.

El análisis debe incluir:

1. Las 7-10 piedras y cristales más compatibles con esta combinación astrológica, ordenados por nivel de compatibilidad.
2. Para cada piedra/cristal:
   - Propiedades energéticas y metafísicas
   - Beneficios específicos para esta combinación astrológica
   - Chakras asociados y cómo ayuda a equilibrarlos
   - Formas recomendadas de uso (joyería, meditación, colocación en el hogar)
   - Rituales o prácticas para potenciar sus efectos

3. Explicación de cómo estas piedras pueden ayudar a:
   - Potenciar las fortalezas de estos signos
   - Mitigar los desafíos o aspectos desafiantes
   - Equilibrar los elementos (fuego, tierra, aire, agua) presentes en la carta

4. Combinaciones recomendadas de piedras para propósitos específicos (amor, prosperidad, creatividad, protección, etc.)

Basa tu análisis en las enseñanzas de expertos en cristaloterapia y astrología como Judy Hall, Katrina Raphaell, y Hibiscus Moon, combinando conocimientos tradicionales con enfoques contemporáneos.

Utiliza un lenguaje accesible pero profundo, que ofrezca tanto comprensión teórica como aplicaciones prácticas para el desarrollo personal y espiritual.
"""

        logger.info(f"Enviando solicitud a OpenAI para análisis de piedras y cristales")

        # Enviar solicitud a OpenAI
        full_url = f"{OPENAI_SERVICE_URL}/generate"
        logger.info(f"URL completa: {full_url}")

        response = requests.post(
            full_url,
            json={
                "prompt": prompt,
                "max_tokens": 2000,
                "temperature": 0.7
            },
            headers={"X-API-Key": api_key}
        )

        if response.status_code != 200:
            logger.error(f"Error al generar análisis de piedras: {response.text}")
            return None

        result = response.json()
        logger.info(f"Texto generado: {len(result.get('text', ''))} caracteres")

        return result.get("text")
    except Exception as e:
        logger.error(f"Error al generar análisis de piedras: {str(e)}")
        import traceback
        logger.error(f"Traceback: {traceback.format_exc()}")
        return None

@app.route('/health', methods=['GET'])
def health():
    """Endpoint para verificar la salud del servicio."""
    return jsonify({"status": "up"}), 200

@app.route('/gemstones', methods=['POST'])
def gemstones():
    """Endpoint para generar un análisis de piedras y cristales compatibles."""
    # Verificar API key
    api_key = request.headers.get('X-API-Key')
    if not api_key or not verify_api_key(api_key):
        logger.warning(f"Intento de acceso con API key inválida: {api_key}")
        return jsonify({"error": "API key inválida o faltante"}), 401

    # Obtener datos de la solicitud
    data = request.get_json()
    sun_sign = data.get('sun_sign', '')
    moon_sign = data.get('moon_sign', '')
    ascendant = data.get('ascendant', '')

    # Validar datos requeridos
    if not sun_sign:
        logger.warning("Solicitud con datos incompletos")
        return jsonify({"error": "Falta el signo solar"}), 400

    try:
        gemstones_data = {
            'sun_sign': sun_sign,
            'moon_sign': moon_sign or "No disponible",
            'ascendant': ascendant or "No disponible"
        }

        # Generar el análisis de piedras
        gemstones_text = generate_gemstones_analysis(gemstones_data, api_key)
        if not gemstones_text:
            return jsonify({"error": "No se pudo generar el análisis de piedras y cristales"}), 500

        # Simular datos estructurados para las piedras y cristales
        # En una implementación real, estos datos se extraerían del análisis o de una base de datos
        gemstones = [
            {
                "name": "Citrino",
                "compatibility": 95,
                "properties": "Energía solar, abundancia, confianza",
                "chakras": ["Plexo solar"],
                "benefits": "Potencia la creatividad y la expresión personal de Leo",
                "usage": "Collar o anillo, meditación con la piedra sobre el plexo solar"
            },
            {
                "name": "Ámbar",
                "compatibility": 92,
                "properties": "Protección, curación, energía positiva",
                "chakras": ["Sacro", "Plexo solar"],
                "benefits": "Amplifica el carisma natural y la vitalidad de Leo",
                "usage": "Pulsera o colgante, colocación cerca de ventanas soleadas"
            },
            {
                "name": "Piedra Luna",
                "compatibility": 90,
                "properties": "Intuición, equilibrio emocional, feminidad",
                "chakras": ["Corona", "Tercer ojo"],
                "benefits": "Equilibra la energía lunar de Cáncer con la solar de Leo",
                "usage": "Meditación durante la luna llena, joyería"
            },
            {
                "name": "Cuarzo Rosa",
                "compatibility": 88,
                "properties": "Amor, compasión, paz",
                "chakras": ["Corazón"],
                "benefits": "Suaviza la intensidad de Leo y fomenta relaciones armoniosas",
                "usage": "Llevar cerca del corazón, colocar en el dormitorio"
            },
            {
                "name": "Labradorita",
                "compatibility": 85,
                "properties": "Transformación, protección, magia",
                "chakras": ["Tercer ojo", "Garganta"],
                "benefits": "Potencia la intuición y la comunicación clara",
                "usage": "Meditación, joyería, colocación en espacios de trabajo creativo"
            }
        ]

        # Preparar respuesta
        response = {
            "gemstones_analysis": gemstones_text,
            "top_gemstones": gemstones,
            "data": {
                "sun_sign": sun_sign,
                "moon_sign": moon_sign,
                "ascendant": ascendant
            }
        }

        logger.info(f"Análisis de piedras y cristales generado exitosamente para {sun_sign}")
        return jsonify(response)

    except Exception as e:
        logger.error(f"Error al procesar solicitud de análisis de piedras: {str(e)}")
        return jsonify({"error": f"Error interno: {str(e)}"}), 500

if __name__ == "__main__":
    app.run(debug=False, host="0.0.0.0", port=5035)
