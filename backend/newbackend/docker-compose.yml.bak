version: '3.8'

services:
  auth_service:
    build:
      context: ./auth_service
      dockerfile: Dockerfile
    ports:
      - "8050:5050"
    environment:
      - JWT_SECRET_KEY=astrofuturo_secret_key
      - ADMIN_USERNAME=admin
      - ADMIN_PASSWORD=astrofuturo2023
      - ADMIN_KEY=astrofuturo_admin_key
    volumes:
      - auth_data:/app/data
    restart: unless-stopped

  api_gateway:
    build:
      context: ./api_gateway
      dockerfile: Dockerfile
    ports:
      - "9000:5000"  # Cambiado a 9000
    environment:
      - AUTH_SERVICE_URL=http://auth_service:5050
      - ZODIAC_SERVICE_URL=http://zodiac_service:5001/zodiac
      - MUSIC_SERVICE_URL=http://music_service:5002/music
      - ASTRONOMY_SERVICE_URL=http://astronomy_service:5003/astronomy
      - WEATHER_SERVICE_URL=http://weather_service:5004/weather
      - ASTRO_REPORT_SERVICE_URL=http://astro_report_service:5006/astro_report
      - NEWS_SERVICE_URL=http://news_service:5007/news
      - PDF_SERVICE_URL=http://pdf_service:5008/generate_pdf
      - COMPATIBILITY_SERVICE_URL=http://compatibility_service:5009/compatibility
      - LOCATION_SERVICE_URL=http://location_service:5011/location
      - EMAIL_SERVICE_URL=http://email_service:5012/email
      - WHATSAPP_SERVICE_URL=http://whatsapp_service:5013/whatsapp
      - PAYMENT_SERVICE_URL=http://payment_service:5014
      - MOVIE_SERVICE_URL=http://movie_service:5000/api/movies
      - ASTRO_CHART_SERVICE_URL=http://astro_chart_service:5015/astro_chart
      - GEOGRAPHIC_SERVICE_URL=http://geographic_service:5025/geographic
      - HOUSES_SERVICE_URL=http://houses_service:5030/houses
      - GEMSTONES_SERVICE_URL=http://gemstones_service:5035/gemstones
      - OPENAI_SERVICE_URL=http://openai_service:5010/generate
    depends_on:
      - auth_service
      - zodiac_service
      - astro_report_service
      - news_service
      - compatibility_service
      - location_service
      - geographic_service
      - houses_service
      - gemstones_service
      - openai_service
      - astro_chart_service
    restart: unless-stopped

  zodiac_service:
    build: ./zodiac_service
    ports:
      - "8001:5001"
    environment:
      - AUTH_SERVICE_URL=http://auth_service:5050
    volumes:
      - zodiac_data:/app/data
    depends_on:
      - auth_service
    restart: unless-stopped

  astro_report_service:
    build: ./astro_report_service
    ports:
      - "8006:5006"
    environment:
      - AUTH_SERVICE_URL=http://auth_service:5050
      - OPENAI_SERVICE_URL=http://openai_service:5010/generate
    volumes:
      - astro_report_data:/app/data
    depends_on:
      - auth_service
      - openai_service
    restart: unless-stopped

  news_service:
    build: ./news_service
    ports:
      - "8007:5007"
    environment:
      - AUTH_SERVICE_URL=http://auth_service:5050
      - OPENAI_SERVICE_URL=http://openai_service:5010/generate
    volumes:
      - news_data:/app/data
    depends_on:
      - auth_service
      - openai_service
    restart: unless-stopped

  compatibility_service:
    build: ./compatibility_service
    ports:
      - "8009:5009"
    environment:
      - AUTH_SERVICE_URL=http://auth_service:5050
      - OPENAI_SERVICE_URL=http://openai_service:5010/generate
    volumes:
      - compatibility_data:/data
    depends_on:
      - auth_service
      - openai_service
    restart: unless-stopped

  openai_service:
    build: ./openai_service
    ports:
      - "8010:5010"
    environment:
      - AUTH_SERVICE_URL=http://auth_service:5050
    volumes:
      - ./openai_service/.env:/app/.env
    depends_on:
      - auth_service
    restart: unless-stopped

  location_service:
    build: ./location_service
    ports:
      - "8011:5011"
    environment:
      - AUTH_SERVICE_URL=http://auth_service:5050
      - OPENAI_SERVICE_URL=http://openai_service:5010/generate
      - ZODIAC_SERVICE_URL=http://zodiac_service:5001/zodiac
    volumes:
      - location_data:/app/data
    depends_on:
      - auth_service
      - openai_service
      - zodiac_service
    restart: unless-stopped

  geographic_service:
    build: ./geographic_service
    ports:
      - "8025:5025"
    environment:
      - AUTH_SERVICE_URL=http://auth_service:5050
      - OPENAI_SERVICE_URL=http://openai_service:5010/generate
    volumes:
      - geographic_data:/data
    depends_on:
      - auth_service
      - openai_service
    restart: unless-stopped

  houses_service:
    build: ./houses_service
    ports:
      - "8030:5030"
    environment:
      - AUTH_SERVICE_URL=http://auth_service:5050
      - OPENAI_SERVICE_URL=http://openai_service:5010/generate
    volumes:
      - houses_data:/data
    depends_on:
      - auth_service
      - openai_service
    restart: unless-stopped

  gemstones_service:
    build: ./gemstones_service
    ports:
      - "8035:5035"
    environment:
      - AUTH_SERVICE_URL=http://auth_service:5050
      - OPENAI_SERVICE_URL=http://openai_service:5010/generate
    volumes:
      - gemstones_data:/data
    depends_on:
      - auth_service
      - openai_service
    restart: unless-stopped

  astro_chart_service:
    build: ./astro_chart_service
    ports:
      - "8015:5015"
    environment:
      - AUTH_SERVICE_URL=http://auth_service:5050
      - ASTRONOMY_SERVICE_URL=http://astronomy_service:5003/astronomy
      - ZODIAC_SERVICE_URL=http://zodiac_service:5001/zodiac
      - OPENAI_SERVICE_URL=http://openai_service:5010/generate
    volumes:
      - astro_chart_data:/data
    depends_on:
      - auth_service
      - zodiac_service
      - openai_service
    restart: unless-stopped

  payment_service:
    build: ./payment_service
    ports:
      - "8014:5014"
    environment:
      - AUTH_SERVICE_URL=http://auth_service:5050
    volumes:
      - ./payment_service/.env:/app/.env
      - payment_data:/data
    depends_on:
      - auth_service
    restart: unless-stopped

volumes:
  auth_data:
  zodiac_data:
  astro_report_data:
  news_data:
  compatibility_data:
  location_data:
  geographic_data:
  houses_data:
  gemstones_data:
  astro_chart_data:
  payment_data:
